{
  "name": "angelscript-lsp",
  "displayName": "client",
  "description": "AngelScript C++ LSP",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gaftherman/angelscript-lsp.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "angelscript",
        "aliases": [
          "AngelScript",
          "angelscript"
        ],
        "extensions": [
          ".as"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[angelscript]": {
        "editor.quickSuggestions": {
          "other": "on",
          "comments": "off",
          "strings": "off"
        },
        "editor.suggestOnTriggerCharacters": true,
        "editor.wordBasedSuggestions": "off",
        "editor.semanticHighlighting.enabled": true
      }
    },
    "configuration": {
      "type": "object",
      "title": "AngelScript Language Server",
      "properties": {
        "angelscript.preprocessorDefines": {
          "type": "array",
          "scope": "resource",
          "items": {
            "type": "string"
          },
          "default": [
            "DEBUG_MODE"
          ],
          "markdownDescription": "List of preprocessor words defined for conditional compilation (`#if WORD` / `#endif`)."
        },
        "angelscript.searchDirectories": {
          "type": "array",
          "scope": "resource",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Custom directory search paths for resolving included script files (`#include \"path.as\"`)."
        },
        "angelscript.predefinedFile": {
          "type": "string",
          "scope": "resource",
          "default": "as.predefined",
          "markdownDescription": "Path to the custom C++ engine predefine file (`as.predefined`)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}