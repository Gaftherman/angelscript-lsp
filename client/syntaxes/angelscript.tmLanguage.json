{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "AngelScript",
  "scopeName": "source.angelscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#modifiers" },
    { "include": "#namespaces" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.angelscript",
          "begin": "/\\*\\*",
          "end": "\\*/",
          "patterns": [
            {
              "match": "([@\\\\](?:access|permission|visibility))\\s+(public|private|protected|package|internal)\\b",
              "captures": {
                "1": { "name": "storage.type.class.doxygen.angelscript storage.type.class.jsdoc.angelscript keyword.other.documentation.angelscript" },
                "2": { "name": "constant.language.access-type.jsdoc.angelscript constant.language.access-type.doxygen.angelscript storage.type.modifier.angelscript" }
              }
            },
            {
              "match": "([@\\\\](?:param|tparam))\\s+([A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "1": { "name": "storage.type.class.doxygen.angelscript storage.type.class.jsdoc.angelscript keyword.other.documentation.angelscript" },
                "2": { "name": "variable.other.jsdoc.angelscript variable.other.doxygen.angelscript" }
              }
            },
            {
              "match": "\\{([^}]+)\\}",
              "captures": {
                "0": { "name": "entity.name.type.instance.jsdoc.angelscript entity.name.type.doxygen.angelscript" }
              }
            },
            {
              "name": "storage.type.class.doxygen.angelscript storage.type.class.jsdoc.angelscript keyword.other.documentation.angelscript",
              "match": "[@\\\\][A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "markup.inline.raw.string.angelscript",
              "match": "`[^`]+`"
            }
          ]
        },
        {
          "name": "comment.block.angelscript",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.documentation.angelscript",
          "begin": "///",
          "end": "$\n?",
          "patterns": [
            {
              "match": "([@\\\\](?:access|permission|visibility))\\s+(public|private|protected|package|internal)\\b",
              "captures": {
                "1": { "name": "storage.type.class.doxygen.angelscript storage.type.class.jsdoc.angelscript keyword.other.documentation.angelscript" },
                "2": { "name": "constant.language.access-type.jsdoc.angelscript constant.language.access-type.doxygen.angelscript storage.type.modifier.angelscript" }
              }
            },
            {
              "match": "([@\\\\](?:param|tparam))\\s+([A-Za-z_][A-Za-z0-9_]*)",
              "captures": {
                "1": { "name": "storage.type.class.doxygen.angelscript storage.type.class.jsdoc.angelscript keyword.other.documentation.angelscript" },
                "2": { "name": "variable.other.jsdoc.angelscript variable.other.doxygen.angelscript" }
              }
            },
            {
              "match": "\\{([^}]+)\\}",
              "captures": {
                "0": { "name": "entity.name.type.instance.jsdoc.angelscript entity.name.type.doxygen.angelscript" }
              }
            },
            {
              "name": "storage.type.class.doxygen.angelscript storage.type.class.jsdoc.angelscript keyword.other.documentation.angelscript",
              "match": "[@\\\\][A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "markup.inline.raw.string.angelscript",
              "match": "`[^`]+`"
            }
          ]
        },
        {
          "name": "comment.line.double-slash.angelscript",
          "begin": "//",
          "end": "$\n?"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.angelscript",
          "begin": "^\\s*(#)\\s*(include)\\b",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.directive.angelscript keyword.control.directive.include.angelscript" },
            "2": { "name": "keyword.control.directive.include.angelscript" }
          },
          "end": "$\n?",
          "patterns": [
            {
              "name": "string.quoted.other.lt-gt.include.angelscript",
              "begin": "<",
              "end": ">"
            },
            {
              "name": "string.quoted.double.include.angelscript",
              "begin": "\"",
              "end": "\""
            }
          ]
        },
        {
          "name": "meta.preprocessor.conditional.angelscript",
          "begin": "^\\s*(#)\\s*(ifdef|ifndef|if|elif|else|endif)\\b",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.directive.angelscript keyword.control.directive.conditional.angelscript" },
            "2": { "name": "keyword.control.directive.conditional.angelscript" }
          },
          "end": "$\n?",
          "patterns": [
            {
              "name": "entity.name.other.preprocessor.macro.angelscript",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        },
        {
          "name": "meta.preprocessor.angelscript",
          "begin": "^\\s*(#)\\s*([A-Za-z_][A-Za-z0-9_]*)\\b",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.directive.angelscript keyword.control.directive.angelscript" },
            "2": { "name": "keyword.control.directive.angelscript" }
          },
          "end": "$\n?"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.angelscript",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.angelscript",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.angelscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.angelscript",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.angelscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.angelscript",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.angelscript",
          "match": "\\b0[xX][0-9a-fA-F]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.binary.angelscript",
          "match": "\\b0[bB][01]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.float.angelscript",
          "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?[fFdD]?\\b"
        },
        {
          "name": "constant.numeric.decimal.angelscript",
          "match": "\\b[0-9]+[uUlL]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.bool.true.angelscript",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.bool.false.angelscript",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.angelscript",
          "match": "\\bnull\\b"
        },
        {
          "name": "variable.other.enummember.angelscript constant.other.enum.angelscript",
          "match": "\\b[A-Z_][A-Z0-9_]{2,}\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.angelscript",
          "match": "\\b(if|else|switch|case|default)\\b"
        },
        {
          "name": "keyword.control.repeat.angelscript",
          "match": "\\b(for|foreach|while|do)\\b"
        },
        {
          "name": "keyword.control.flow.angelscript",
          "match": "\\b(return|break|continue)\\b"
        },
        {
          "name": "keyword.control.exception.angelscript",
          "match": "\\b(try|catch)\\b"
        },
        {
          "name": "keyword.control.conditional.angelscript",
          "match": "\\b(is|not|and|or|xor|in)\\b"
        },
        {
          "name": "keyword.operator.new.angelscript",
          "match": "\\bnew\\b"
        },
        {
          "name": "keyword.operator.delete.angelscript",
          "match": "\\bdelete\\b"
        },
        {
          "name": "keyword.operator.cast.angelscript",
          "match": "\\bcast\\b"
        },
        {
          "name": "keyword.other.angelscript",
          "match": "\\b(import|from|using|namespace|get|set)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.class.angelscript",
          "match": "\\b(class|interface|enum|mixin|struct|typedef|funcdef)\\b"
        },
        {
          "name": "storage.type.built-in.primitive.angelscript",
          "match": "\\b(void|int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|float|double|bool|auto)\\b"
        },
        {
          "name": "support.type.angelscript",
          "match": "\\b(string|array|dictionary)\\b"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.reference.angelscript",
          "match": "&inout\\b|&in\\b|&out\\b|&"
        },
        {
          "name": "storage.type.handle.angelscript storage.modifier.pointer.angelscript keyword.operator.handle.angelscript",
          "match": "@"
        },
        {
          "name": "storage.modifier.pointer.angelscript",
          "match": "\\*"
        },
        {
          "name": "storage.type.modifier.access.control.angelscript keyword.other.modifier.angelscript",
          "match": "\\b(private|protected|public)\\b"
        },
        {
          "name": "keyword.other.modifier.angelscript storage.modifier.angelscript",
          "match": "\\b(const|override|explicit|property|shared|abstract|final|external)\\b"
        }
      ]
    },
    "namespaces": {
      "patterns": [
        {
          "name": "entity.name.namespace.angelscript",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*::)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.destructor.angelscript",
          "match": "~[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.angelscript",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.class.angelscript",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.angelscript",
          "match": "==|!=|<=|>=|&&|\\|\\||\\+\\+|--|\\+=|-=|\\*=|/=|%=|<<|>>|\\^|~|\\?|:|=|\\+|-|\\*|/|%"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.namespace.angelscript punctuation.separator.scope.cpp punctuation.delimiter.angelscript",
          "match": "::"
        },
        {
          "name": "punctuation.delimiter.angelscript",
          "match": ";|,"
        },
        {
          "name": "punctuation.bracket.angelscript",
          "match": "\\(|\\)|\\{|\\}|\\[|\\]"
        }
      ]
    }
  }
}
